#!/bin/sh /etc/rc.common

USE_PROCD=1
START=80
STOP=10

PROG=/usr/bin/quickfile-go-api
CONFIG=quickfile-go

start_service() {
	[ -x "$PROG" ] || return 1

	config_load "$CONFIG"
	local enabled listen_addr listen_port enable_terminal max_upload_mb max_edit_mb
	config_get_bool enabled main enabled 1
	[ "$enabled" = "1" ] || return 0

	config_get listen_addr main listen_addr 'auto'
	config_get listen_port main listen_port '8989'
	config_get_bool enable_terminal main enable_terminal 1
	config_get max_upload_mb main max_upload_mb '0'
	config_get max_edit_mb main max_edit_mb '0'

	# LAN-only default: resolve "auto" to network.lan.ipaddr.
	# This avoids exposing the backend on all interfaces by default.
	if [ -z "$listen_addr" ] || [ "$listen_addr" = "auto" ]; then
		listen_addr="$(uci -q get network.lan.ipaddr 2>/dev/null)"
		[ -n "$listen_addr" ] || listen_addr="192.168.1.1"
	fi

	procd_open_instance
	procd_set_param command "$PROG" \
		-listen "${listen_addr}:${listen_port}" \
		-enable-exec="$enable_terminal" \
		-max-upload-mb "$max_upload_mb" \
		-max-edit-mb "$max_edit_mb"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	restart
}
